<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title=""
    Width="500"
    Height="Auto"
    AllowsTransparency="True"
    Background="Transparent"
    FontFamily="Futura"
    Foreground="White"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    SizeToContent="Height"
    Topmost="False"
    WindowStartupLocation="CenterOwner"
    WindowStyle="None">
    <Window.Resources>
        <Style BasedOn="{StaticResource CommonDialogTextBlockStyle}" TargetType="TextBlock" />
    </Window.Resources>
    <Border
        x:Name="DialogBorder"
        Background="#1E1E1E"
        BorderBrush="#3F3F46"
        BorderThickness="1"
        CornerRadius="5"
        Effect="{x:Null}">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40" />
                <RowDefinition Height="*" />
                <RowDefinition Height="50" />
            </Grid.RowDefinitions>

            <!--  Barra de título  -->
            <Border Grid.Row="0" CornerRadius="5,5,0,0">
                <Grid>
                    <TextBlock
                        x:Name="TitleText"
                        Margin="15,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Foreground="White"
                        Text="" />

                    <Button
                        x:Name="CloseButton"
                        Margin="0,0,5,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Content="✕"
                        Style="{StaticResource CommonMutedCloseButtonStyle}" />
                </Grid>
            </Border>

            <!--  Conteúdo principal  -->
            <Grid Grid.Row="1" Margin="15">
                <ScrollViewer
                    VerticalAlignment="Stretch"
                    HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="SystemInfoPanel" Orientation="Vertical">
                        <TextBlock
                            x:Name="FallbackText"
                            Margin="0,0,0,10"
                            FontSize="12"
                            Foreground="LightGray"
                            Text="Informações do sistema indisponíveis"
                            Visibility="Collapsed" />

                        <Border
                            Width="30"
                            Height="30"
                            Margin="0,0,0,10"
                            HorizontalAlignment="Center"
                            Background="#383838"
                            CornerRadius="15">
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontFamily="Segoe MDL2 Assets"
                                FontSize="16"
                                Foreground="White"
                                Text="&#xE783;" />
                        </Border>

                        <TextBlock
                            HorizontalAlignment="Center"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Text="Informações do sistema" />

                        <!--  Seção: Máquina  -->
                        <StackPanel Margin="0,0,0,10" Orientation="Vertical">
                            <TextBlock
                                Margin="0,0,0,5"
                                FontSize="14"
                                FontWeight="SemiBold"
                                Foreground="White"
                                Text="Máquina" />
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Grid.Row="0"
                                    Grid.Column="0"
                                    Foreground="LightGray"
                                    Text="Chassis SKU" />
                                <TextBlock
                                    x:Name="MachineSKUText"
                                    Grid.Row="0"
                                    Grid.Column="1"
                                    Foreground="LightGray" />
                                <TextBlock
                                    Grid.Row="1"
                                    Grid.Column="0"
                                    Foreground="LightGray"
                                    Text="Fabricante" />
                                <TextBlock
                                    x:Name="ManufacturerText"
                                    Grid.Row="1"
                                    Grid.Column="1"
                                    Foreground="LightGray" />
                                <TextBlock
                                    Grid.Row="2"
                                    Grid.Column="0"
                                    Foreground="LightGray"
                                    Text="Modelo" />
                                <TextBlock
                                    x:Name="ModelText"
                                    Grid.Row="2"
                                    Grid.Column="1"
                                    Foreground="LightGray" />
                            </Grid>
                        </StackPanel>

                        <!--  Seção: Identificação  -->
                        <StackPanel Margin="0,0,0,10" Orientation="Vertical">
                            <TextBlock
                                Margin="0,0,0,5"
                                FontSize="14"
                                FontWeight="SemiBold"
                                Foreground="White"
                                Text="Identificação" />
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Grid.Row="0"
                                    Grid.Column="0"
                                    Foreground="LightGray"
                                    Text="Número de série" />
                                <TextBlock
                                    x:Name="SerialText"
                                    Grid.Row="0"
                                    Grid.Column="1"
                                    Foreground="LightGray" />
                                <Button
                                    x:Name="CopySerialButton"
                                    Grid.Row="0"
                                    Grid.Column="2"
                                    Width="25"
                                    Height="25"
                                    Margin="5,0,0,0"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Background="#383838"
                                    BorderBrush="#444444"
                                    BorderThickness="1"
                                    ToolTip="Copiar número de série"
                                    Visibility="Collapsed">
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontFamily="Segoe MDL2 Assets"
                                        FontSize="14"
                                        Foreground="White"
                                        Text="&#xE8C8;" />
                                </Button>
                                <TextBlock
                                    Grid.Row="1"
                                    Grid.Column="0"
                                    Foreground="LightGray"
                                    Text="Processador" />
                                <TextBlock
                                    x:Name="ProcessorText"
                                    Grid.Row="1"
                                    Grid.Column="1"
                                    Foreground="LightGray" />
                            </Grid>
                        </StackPanel>

                        <!--  Seção: Sistema Operacional  -->
                        <StackPanel Margin="0,0,0,10" Orientation="Vertical">
                            <TextBlock
                                Margin="0,0,0,5"
                                FontSize="14"
                                FontWeight="SemiBold"
                                Foreground="White"
                                Text="Sistema operacional" />
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Grid.Row="0"
                                    Grid.Column="0"
                                    Foreground="LightGray"
                                    Text="Edição" />
                                <TextBlock
                                    x:Name="OSCaptionText"
                                    Grid.Row="0"
                                    Grid.Column="1"
                                    Foreground="LightGray" />
                                <TextBlock
                                    Grid.Row="1"
                                    Grid.Column="0"
                                    Foreground="LightGray"
                                    Text="Arquitetura" />
                                <TextBlock
                                    x:Name="OSArchText"
                                    Grid.Row="1"
                                    Grid.Column="1"
                                    Foreground="LightGray" />
                                <TextBlock
                                    Grid.Row="2"
                                    Grid.Column="0"
                                    Foreground="LightGray"
                                    Text="Build" />
                                <TextBlock
                                    x:Name="OSBuildText"
                                    Grid.Row="2"
                                    Grid.Column="1"
                                    Foreground="LightGray" />
                                <TextBlock
                                    Grid.Row="3"
                                    Grid.Column="0"
                                    Foreground="LightGray"
                                    Text="Memória RAM" />
                                <TextBlock
                                    x:Name="MemoryText"
                                    Grid.Row="3"
                                    Grid.Column="1"
                                    Foreground="LightGray" />
                                <TextBlock
                                    Grid.Row="4"
                                    Grid.Column="0"
                                    Foreground="LightGray"
                                    Text="Tipo de Boot" />
                                <TextBlock
                                    x:Name="BootTypeText"
                                    Grid.Row="4"
                                    Grid.Column="1"
                                    Foreground="LightGray" />
                            </Grid>
                        </StackPanel>

                        <!--  Seção: Discos  -->
                        <StackPanel Margin="0,10,0,10" Orientation="Vertical">
                            <TextBlock
                                Margin="0,0,0,5"
                                FontSize="14"
                                FontWeight="SemiBold"
                                Foreground="White"
                                Text="Discos" />
                            <Border
                                Padding="8"
                                Background="#2E2E2E"
                                BorderBrush="#444444"
                                BorderThickness="1">
                                <TextBlock
                                    x:Name="DisksText"
                                    Foreground="#D4D4D4"
                                    TextWrapping="Wrap" />
                            </Border>
                        </StackPanel>

                        <!--  Seção: GPUs  -->
                        <StackPanel Margin="0,0,0,10" Orientation="Vertical">
                            <TextBlock
                                Margin="0,0,0,5"
                                FontSize="14"
                                FontWeight="SemiBold"
                                Foreground="White"
                                Text="GPUs" />
                            <Border
                                Padding="8"
                                Background="#2E2E2E"
                                BorderBrush="#444444"
                                BorderThickness="1">
                                <TextBlock
                                    x:Name="GpusText"
                                    Foreground="#D4D4D4"
                                    TextWrapping="Wrap" />
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Border>
</Window>