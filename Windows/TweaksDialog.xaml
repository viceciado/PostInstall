<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Ajustes gerais"
    Width="750"
    Height="Auto"
    MaxHeight="700"
    AllowsTransparency="True"
    Background="Transparent"
    FontFamily="Futura"
    Foreground="White"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    SizeToContent="Height"
    WindowStartupLocation="CenterOwner"
    WindowStyle="None">

    <Window.Resources>
        <Style BasedOn="{StaticResource CommonCheckBoxStyle}" TargetType="CheckBox" />

        <Style
            x:Key="ActionButtonStyle"
            BasedOn="{StaticResource CommonDialogButtonStyle}"
            TargetType="Button">
            <Setter Property="Background" Value="#993233" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="15,10" />
            <Setter Property="Margin" Value="0,5" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
        </Style>

        <Style
            x:Key="FilterButtonStyle"
            BasedOn="{StaticResource CommonDialogButtonStyle}"
            TargetType="Button">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Background" Value="#3F3F46" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Margin" Value="2" />
        </Style>

    </Window.Resources>

    <Border
        x:Name="DialogBorder"
        Background="#1E1E1E"
        BorderBrush="#3F3F46"
        BorderThickness="1"
        CornerRadius="5"
        Effect="{x:Null}">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" CornerRadius="5,5,0,0">
                <Grid>
                    <TextBlock
                        x:Name="TitleText"
                        Margin="15,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Foreground="White"
                        Text="Ajustes gerais" />

                    <Button
                        x:Name="CloseButton"
                        Margin="0,0,5,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Content="✕"
                        Style="{StaticResource CommonMutedCloseButtonStyle}" />
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="40" />
                    <ColumnDefinition Width="250" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Vertical">
                    <Border
                        Width="30"
                        Height="30"
                        Margin="0,0,0,10"
                        HorizontalAlignment="Center"
                        Background="#383838"
                        CornerRadius="15">
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontFamily="Segoe MDL2 Assets"
                            FontSize="16"
                            Foreground="White"
                            Text="&#xE15E;" />
                    </Border>

                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock
                            Margin="0,0,0,5"
                            HorizontalAlignment="Center"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Text="Ajustes" />
                        <TextBlock
                            Margin="0,0,0,10"
                            HorizontalAlignment="Center"
                            FontSize="12"
                            Text="Selecione os ajustes que deseja aplicar ao sistema" />

                        <StackPanel
                            x:Name="FilterButtonsPanel"
                            Margin="0,0,0,15"
                            HorizontalAlignment="Center"
                            Orientation="Horizontal" />

                        <ScrollViewer
                            x:Name="TweaksScrollViewer"
                            Width="400"
                            Height="400"
                            Margin="0,0,0,15"
                            Padding="10"
                            Background="#383838"
                            BorderBrush="#505050"
                            BorderThickness="1"
                            VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="TweaksStackPanel" Orientation="Vertical" />
                            <ScrollViewer.Resources>
                                <!--  Estilo discreto para a scrollbar  -->
                                <Style BasedOn="{StaticResource SlimScrollBarStyle}" TargetType="{x:Type ScrollBar}" />
                            </ScrollViewer.Resources>
                        </ScrollViewer>

                    </StackPanel>
                </StackPanel>

                <Border
                    Grid.Column="1"
                    Width="1"
                    HorizontalAlignment="Center"
                    Background="#505050" />

                <StackPanel Grid.Column="2" Orientation="Vertical">
                    <Border
                        Width="30"
                        Height="30"
                        Margin="0,0,0,10"
                        HorizontalAlignment="Center"
                        Background="#383838"
                        CornerRadius="15">
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontFamily="Segoe MDL2 Assets"
                            FontSize="16"
                            Foreground="White"
                            Text="&#xE945;" />
                    </Border>

                    <TextBlock
                        Margin="0,0,0,10"
                        HorizontalAlignment="Center"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Text="Ações rápidas" />

                    <Button
                        x:Name="RecommendedTweaksButton"
                        Background="#28A745"
                        Content="Marcar recomendados"
                        Style="{StaticResource ActionButtonStyle}" />

                    <Button
                        x:Name="RestoreDefaultsButton"
                        Background="#2D2D30"
                        Content="Desfazer alterações"
                        IsEnabled="False"
                        Style="{StaticResource ActionButtonStyle}" />

                    <Button
                        x:Name="ApplySelectedTweaksButton"
                        Background="#2D2D30"
                        Content="Aplicar"
                        IsEnabled="False"
                        Style="{StaticResource ActionButtonStyle}" />

                    <Border
                        Height="1"
                        Margin="0,15"
                        Background="#505050" />

                    <Border
                        Width="30"
                        Height="30"
                        Margin="0,0,0,10"
                        HorizontalAlignment="Center"
                        Background="#383838"
                        CornerRadius="15">
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontFamily="Segoe MDL2 Assets"
                            FontSize="16"
                            Foreground="White"
                            Text="&#xF259;" />
                    </Border>

                    <TextBlock
                        Margin="0,0,0,10"
                        HorizontalAlignment="Center"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Text="Ferramentas" />

                    <Button
                        x:Name="SystemPropPerfButton"
                        Background="#0078D4"
                        Content="Aparência e desemepnho"
                        Style="{StaticResource ActionButtonStyle}" />

                    <Button
                        x:Name="InstalledUpdatesButton"
                        Background="#3F3F46"
                        Content="Ver atualizações instaladas"
                        Style="{StaticResource ActionButtonStyle}" />

                    <Button
                        x:Name="RarRegButton"
                        Background="#3F3F46"
                        Content="Registrar o WinRAR"
                        Style="{StaticResource ActionButtonStyle}" />
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>