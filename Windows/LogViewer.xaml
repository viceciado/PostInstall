<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Visualizador de Logs de Instalação"
    Width="900"
    Height="700"
    AllowsTransparency="True"
    Background="Transparent"
    FontFamily="Futura"
    Foreground="White"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    Topmost="False"
    WindowStartupLocation="CenterOwner"
    WindowStyle="None">

    <Window.Resources>
        <Style BasedOn="{StaticResource CommonDialogInputTextBoxStyle}" TargetType="TextBox" />

        <Style BasedOn="{StaticResource CommonDialogTextBlockStyle}" TargetType="TextBlock" />
    </Window.Resources>

    <Border
        x:Name="DialogBorder"
        Background="#1E1E1E"
        BorderBrush="#3F3F46"
        BorderThickness="1"
        CornerRadius="5"
        Effect="{x:Null}">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!--  Barra de título  -->
            <Border
                Grid.Row="0"
                Background="#2D2D30"
                CornerRadius="5,5,0,0">
                <Grid>
                    <TextBlock
                        x:Name="TitleText"
                        Margin="15,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Foreground="White"
                        Text="Logs de Instalação" />

                    <StackPanel
                        Margin="0,0,5,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                        <Button
                            x:Name="CloseButton"
                            Content="✕"
                            Style="{StaticResource CommonMutedCloseButtonStyle}" />
                    </StackPanel>
                </Grid>
            </Border>

            <!--  Conteúdo principal  -->
            <ScrollViewer
                Grid.Row="1"
                Margin="20"
                HorizontalScrollBarVisibility="Disabled"
                VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="LogContentPanel">
                    <!--  Seção do Log Principal (se existir)  -->
                    <TextBox
                        x:Name="PrimaryLogTextBox"
                        MinHeight="200"
                        MaxHeight="500"
                        Margin="0,0,0,20"
                        AcceptsReturn="True"
                        HorizontalScrollBarVisibility="Auto"
                        IsReadOnly="True"
                        Style="{StaticResource CommonDialogInputTextBoxStyle}"
                        TextWrapping="Wrap"
                        VerticalScrollBarVisibility="Auto"
                        Visibility="Collapsed" />
                    <Grid Margin="15">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!--  TextBox para exibir os logs unificados  -->
                        <TextBox
                            Name="UnifiedLogTextBox"
                            Grid.Row="0"
                            FontFamily="Cascadia Mono"
                            HorizontalScrollBarVisibility="Disabled"
                            IsReadOnly="True"
                            Style="{StaticResource CommonDialogInputTextBoxStyle}"
                            TextWrapping="Wrap"
                            VerticalScrollBarVisibility="Disabled" />
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>