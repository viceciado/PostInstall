<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Visualizador de Logs de Instalação" Width="900" Height="700"
        WindowStyle="None" WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False" Topmost="False"
        AllowsTransparency="True" Background="Transparent" Foreground="White" FontFamily="Futura">
    
    <Window.Resources>
        <Style TargetType="TextBox" BasedOn="{StaticResource CommonDialogInputTextBoxStyle}"/>
        
        <Style TargetType="TextBlock" BasedOn="{StaticResource CommonDialogTextBlockStyle}"/>
    </Window.Resources>
    
    <Border x:Name="DialogBorder" 
            Background="#1E1E1E" 
            BorderBrush="#3F3F46" 
            BorderThickness="1" 
            CornerRadius="5"
            Effect="{x:Null}">
        
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- Barra de título -->
            <Border Grid.Row="0" Background="#2D2D30" CornerRadius="5,5,0,0">
                <Grid>
                    <TextBlock x:Name="TitleText" 
                               Text="Logs de Instalação" 
                               Foreground="White" 
                               FontSize="14" 
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" 
                               HorizontalAlignment="Left" 
                               Margin="15,0"/>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,5,0">
                        <Button x:Name="CloseButton"
                                Content="✕"
                                Style="{StaticResource CommonMutedCloseButtonStyle}"/>
                    </StackPanel>
                </Grid>
            </Border>
            
            <!-- Conteúdo principal -->
            <ScrollViewer Grid.Row="1" Margin="20" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel x:Name="LogContentPanel">
                    <!-- Seção do Log Principal (se existir) -->
                    <TextBox x:Name="PrimaryLogTextBox" 
                             Style="{StaticResource CommonDialogInputTextBoxStyle}"
                             TextWrapping="Wrap" 
                             VerticalScrollBarVisibility="Auto" 
                             HorizontalScrollBarVisibility="Auto"
                             AcceptsReturn="True" 
                             IsReadOnly="True" 
                             MinHeight="200"
                             MaxHeight="500"
                             Margin="0,0,0,20"
                             Visibility="Collapsed"/>
                    <Grid Margin="15">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                    
                        <!-- TextBox para exibir os logs unificados -->
                        <TextBox Name="UnifiedLogTextBox" Grid.Row="0" Style="{StaticResource CommonDialogInputTextBoxStyle}" VerticalScrollBarVisibility="Disabled" HorizontalScrollBarVisibility="Disabled" IsReadOnly="True" FontFamily="Cascadia Mono" TextWrapping="Wrap"/>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>