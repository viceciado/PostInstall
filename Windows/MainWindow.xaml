<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Instalação e configuração do Windows"
    Width="700"
    Height="600"
    AllowsTransparency="True"
    Background="Transparent"
    FontFamily="Futura"
    Foreground="#ffffff"
    ResizeMode="NoResize"
    ShowInTaskbar="True"
    Topmost="False"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None">
    <Window.Resources>
        <Color x:Key="HighlightColor">#993233</Color>
        <Color x:Key="DisabledColor">#CC6666</Color>
        <SolidColorBrush x:Key="HighlightBrush" Color="{StaticResource HighlightColor}" />

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontFamily" Value="Futura" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="FocusBorder"
                            Background="{TemplateBinding Background}"
                            CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="FocusBorder" Property="BorderBrush" Value="White" />
                                <Setter TargetName="FocusBorder" Property="BorderThickness" Value="2" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.6" />
                                <Setter Property="Cursor" Value="Arrow" />
                                <Setter Property="Background" Value="#505050" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RoundButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Width" Value="35" />
            <Setter Property="Height" Value="35" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="FocusBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="18">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="FocusBorder" Property="BorderBrush" Value="White" />
                                <Setter TargetName="FocusBorder" Property="BorderThickness" Value="2" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style
            x:Key="CloseButtonStyle"
            BasedOn="{StaticResource RoundButtonStyle}"
            TargetType="Button">
            <Setter Property="Background" Value="#333333" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="FocusBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="18">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="FocusBorder" Property="BorderBrush" Value="White" />
                                <Setter TargetName="FocusBorder" Property="BorderThickness" Value="2" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="LightGray" />
            <Setter Property="FontFamily" Value="Futura" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="Margin" Value="0,15,0,5" />
        </Style>

        <Style x:Key="MainSubTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="LightGray" />
            <Setter Property="FontFamily" Value="Futura" />
            <Setter Property="FontSize" Value="20" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>

        <Style x:Key="FooterTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="LightGray" />
            <Setter Property="FontFamily" Value="Futura" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="Margin" Value="15,0,0,0" />
        </Style>

        <Style x:Key="FooterButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Tag" Value="{x:Null}" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="FocusBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="3">
                            <TextBlock
                                Margin="3,0"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Style="{StaticResource FooterTextStyle}"
                                Text="{TemplateBinding Content}"
                                TextDecorations="{TemplateBinding Tag}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="FocusBorder" Property="BorderBrush" Value="{StaticResource HighlightBrush}" />
                                <Setter TargetName="FocusBorder" Property="BorderThickness" Value="1" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Tag" Value="Underline" />
                    <Setter Property="Cursor" Value="Hand" />
                    <Setter Property="Background" Value="#555555" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Tag" Value="Underline" />
                    <Setter Property="Foreground" Value="LightBlue" />
                    <Setter Property="Background" Value="#777777" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border
        x:Name="DialogBorder"
        Background="#202020"
        CornerRadius="15"
        Opacity="0.95">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" HorizontalAlignment="Stretch">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel
                    Grid.Column="0"
                    Grid.ColumnSpan="3"
                    Margin="0,15,0,0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontSize="25"
                        Text="Instalação e configuração do Windows" />
                </StackPanel>

                <StackPanel
                    Grid.Column="2"
                    Margin="0,10,10,0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Orientation="Horizontal">
                    <Button
                        x:Name="AvoidSleepButton"
                        Margin="0,0,10,0"
                        Foreground="Yellow"
                        Style="{StaticResource RoundButtonStyle}"
                        ToolTip="Evitar suspensão">
                        <Button.Content>
                            <TextBlock Text="&#xEB50;" />
                        </Button.Content>
                    </Button>
                    <Button
                        x:Name="CloseButton"
                        Style="{StaticResource CloseButtonStyle}"
                        ToolTip="Fechar">
                        <Button.Content>
                            <TextBlock Text="&#xE711;" />
                        </Button.Content>
                    </Button>
                </StackPanel>
            </Grid>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel
                    Margin="20,0,20,0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Orientation="Vertical">

                    <TextBlock
                        HorizontalAlignment="Center"
                        Style="{StaticResource SectionTitleStyle}"
                        Text="Instalação de programas" />
                    <Grid Margin="0,0,0,15" HorizontalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Button
                            x:Name="SelectAndInstallProgramsButton"
                            Grid.Column="0"
                            Width="225"
                            Height="35"
                            Margin="0,0,10,0"
                            Background="#993233"
                            Content="Instalar programas"
                            Style="{StaticResource PrimaryButtonStyle}"
                            ToolTip="Instalar programas usando o Winget" />
                        <Button
                            x:Name="InstallOfficeButton"
                            Grid.Column="1"
                            Width="225"
                            Height="35"
                            Margin="10,0,0,0"
                            Background="#993233"
                            Content="Instalar Office"
                            Style="{StaticResource PrimaryButtonStyle}"
                            ToolTip="Instalar o Office a partir de um arquivo de imagem" />
                    </Grid>

                    <Rectangle
                        Height="1"
                        HorizontalAlignment="Stretch"
                        Fill="Gray" />

                    <TextBlock
                        HorizontalAlignment="Center"
                        Style="{StaticResource SectionTitleStyle}"
                        Text="Aparência e ajustes" />
                    <Grid Margin="0,0,0,15" HorizontalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Button
                            x:Name="ApplyThemeButton"
                            Grid.Column="0"
                            Width="35"
                            Height="35"
                            Background="#993233"
                            Content=""
                            FontFamily="Segoe MDL2 Assets"
                            FontSize="20"
                            Style="{StaticResource PrimaryButtonStyle}"
                            ToolTip="" />
                        <Button
                            x:Name="TweaksButton"
                            Grid.Column="1"
                            Width="192"
                            Height="35"
                            Margin="10,0,10,0"
                            Background="#993233"
                            Content="Ajustes gerais"
                            Style="{StaticResource PrimaryButtonStyle}"
                            ToolTip="Modifique configurações e aplique tweaks" />
                        <Button
                            x:Name="FixPermissionsButton"
                            Grid.Column="2"
                            Width="192"
                            Height="35"
                            Margin="0,0,0,0"
                            Background="#993233"
                            Content="Limpar permissões"
                            Style="{StaticResource PrimaryButtonStyle}"
                            ToolTip="Limpe as permissões antigas de outra instalação do Windows" />
                    </Grid>

                    <Rectangle
                        Height="1"
                        HorizontalAlignment="Stretch"
                        Fill="Gray" />

                    <TextBlock
                        HorizontalAlignment="Center"
                        Style="{StaticResource SectionTitleStyle}"
                        Text="Ativação do sistema" />
                    <Button
                        x:Name="ActivateButton"
                        Width="200"
                        Height="35"
                        Margin="0,0,0,15"
                        HorizontalAlignment="Center"
                        Background="#993233"
                        Content="Ativação"
                        Style="{StaticResource PrimaryButtonStyle}" />

                    <Rectangle
                        Height="1"
                        HorizontalAlignment="Stretch"
                        Fill="Gray" />

                    <TextBlock
                        HorizontalAlignment="Center"
                        Style="{StaticResource SectionTitleStyle}"
                        Text="Drivers" />
                    <Grid HorizontalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Button
                            x:Name="WUpdateButton"
                            Grid.Column="0"
                            Width="35"
                            Height="35"
                            Margin="0,0,0,0"
                            Background="#993233"
                            FontSize="20"
                            Style="{StaticResource PrimaryButtonStyle}"
                            ToolTip="Abrir o Windows Update">
                            <Button.Content>
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontFamily="Segoe MDL2 Assets"
                                    Text="&#xEC27;" />
                            </Button.Content>
                        </Button>
                        <Button
                            x:Name="ImportDriversButton"
                            Grid.Column="1"
                            Width="230"
                            Height="35"
                            Margin="10,0,10,0"
                            Background="#993233"
                            Content="Importar backup de drivers"
                            Style="{StaticResource PrimaryButtonStyle}"
                            ToolTip="Importar arquivos de instalação de drivers" />
                        <Button
                            x:Name="DeviceManagerButton"
                            Grid.Column="2"
                            Width="35"
                            Height="35"
                            Margin="0,0,0,0"
                            Background="#993233"
                            FontSize="20"
                            Style="{StaticResource PrimaryButtonStyle}"
                            ToolTip="Abrir o Gerenciador de Dispositivos">
                            <Button.Content>
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontFamily="Segoe MDL2 Assets"
                                    Text="&#xF211;" />
                            </Button.Content>
                        </Button>
                    </Grid>

                </StackPanel>
            </ScrollViewer>

            <Button
                x:Name="FinalizeInstallButton"
                Grid.Row="2"
                Width="250"
                Height="45"
                Margin="0,20,0,20"
                HorizontalAlignment="Center"
                Background="#993233"
                Content="Finalizar instalação"
                Style="{StaticResource PrimaryButtonStyle}" />

            <Border
                Grid.Row="3"
                Height="30"
                VerticalAlignment="Bottom"
                Background="#333333"
                CornerRadius="0,0,15,15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="450" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button
                        x:Name="FooterStatusButton"
                        Grid.Column="0"
                        Margin="15,4,0,4"
                        HorizontalAlignment="Left"
                        Content="Status:"
                        Style="{StaticResource FooterButtonStyle}"
                        ToolTip="Clique para ver o log de instalação.">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="3">
                                    <TextBlock
                                        Margin="3,0"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        Style="{StaticResource FooterTextStyle}"
                                        Text="{TemplateBinding Content}"
                                        TextDecorations="{TemplateBinding Tag}"
                                        TextTrimming="CharacterEllipsis" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsKeyboardFocused" Value="True">
                                        <Setter Property="BorderBrush" Value="{StaticResource HighlightBrush}" />
                                        <Setter Property="BorderThickness" Value="1" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button
                        x:Name="ScriptVersionButton"
                        Grid.Column="1"
                        Margin="10,4"
                        HorizontalAlignment="Right"
                        Content=""
                        Style="{StaticResource FooterButtonStyle}" />

                    <Button
                        x:Name="AboutButton"
                        Grid.Column="2"
                        Margin="0,4,15,4"
                        HorizontalAlignment="Right"
                        Content="Sobre o sistema"
                        Style="{StaticResource FooterButtonStyle}" />
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>