<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Ativação"
    Width="400"
    Height="Auto"
    AllowsTransparency="True"
    Background="Transparent"
    FontFamily="Futura"
    Foreground="White"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    SizeToContent="Height"
    Topmost="False"
    WindowStartupLocation="CenterOwner"
    WindowStyle="None">
    <Window.Resources>
        <Style
            x:Key="RoundButtonStyle"
            BasedOn="{StaticResource CommonDialogButtonStyle}"
            TargetType="Button">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="30" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Margin" Value="5,0" />
            <Setter Property="Background" Value="#2D2D30" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="FocusBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="15">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="FocusBorder" Property="BorderBrush" Value="White" />
                                <Setter TargetName="FocusBorder" Property="BorderThickness" Value="2" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.7" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style BasedOn="{StaticResource CommonDialogInputTextBoxStyle}" TargetType="TextBox" />
        <Style BasedOn="{StaticResource CommonDialogTextBlockStyle}" TargetType="TextBlock" />
        <Style
            x:Key="OemActivateButtonStyle"
            BasedOn="{StaticResource CommonDialogButtonStyle}"
            TargetType="Button">
            <Setter Property="Background" Value="#2D2D30" />
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="True">
                    <Setter Property="Background" Value="#28A745" />
                </Trigger>
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="IsEnabled" Value="True" />
                        <Condition Property="IsMouseOver" Value="True" />
                    </MultiTrigger.Conditions>
                    <Setter Property="Background" Value="#34C05A" />
                </MultiTrigger>
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="IsEnabled" Value="True" />
                        <Condition Property="IsPressed" Value="True" />
                    </MultiTrigger.Conditions>
                    <Setter Property="Background" Value="#1E8035" />
                </MultiTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border
        x:Name="DialogBorder"
        Background="#1E1E1E"
        BorderBrush="#3F3F46"
        BorderThickness="1"
        CornerRadius="5"
        Effect="{x:Null}">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!--  Barra de título  -->
            <Border Grid.Row="0" CornerRadius="5,5,0,0">
                <Grid>
                    <TextBlock
                        x:Name="TitleText"
                        Margin="15,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Foreground="White"
                        Text="Ativação" />

                    <Button
                        x:Name="CloseButton"
                        Margin="0,0,5,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Content="✕"
                        Style="{StaticResource CommonMutedCloseButtonStyle}" />
                </Grid>
            </Border>

            <!--  Conteúdo principal  -->
            <Grid Grid.Row="1" Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border
                    Width="30"
                    Height="30"
                    Margin="0,0,0,10"
                    HorizontalAlignment="Center"
                    Background="#383838"
                    CornerRadius="15">
                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontFamily="Segoe MDL2 Assets"
                        FontSize="16"
                        Foreground="White"
                        Text="&#xE192;" />
                </Border>

                <!--  Conteúdo do Passo 1  -->
                <StackPanel Grid.Row="1" HorizontalAlignment="Center">
                    <TextBlock
                        Margin="0,0,0,5"
                        HorizontalAlignment="Center"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Text="Ativação OEM" />
                </StackPanel>
                <Grid
                    Grid.Row="2"
                    Grid.Column="0"
                    Height="30"
                    Margin="0,5,0,10">
                    <TextBox
                        x:Name="OemKeyTextBox"
                        Height="30"
                        Padding="5,0,40,0"
                        VerticalAlignment="Center"
                        VerticalContentAlignment="Center"
                        IsReadOnly="True"
                        Text="Clique no botão abaixo para buscar pela chave OEM" />
                    <Button
                        x:Name="CopyOemKeyButton"
                        Width="25"
                        Height="25"
                        Margin="0,0,5,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Content="&#xE16D;"
                        FontFamily="Segoe MDL2 Assets"
                        Style="{StaticResource RoundButtonStyle}"
                        ToolTip="Copiar chave OEM"
                        Visibility="Collapsed" />
                </Grid>

                <StackPanel
                    Grid.Row="3"
                    Grid.Column="0"
                    HorizontalAlignment="Center"
                    Orientation="Horizontal">
                    <Button
                        x:Name="FindOemKeyButton"
                        Width="175"
                        Height="35"
                        Margin="0,0,5,0"
                        Content="Localizar chave OEM"
                        Style="{StaticResource CommonDangerActionButtonStyle}" />
                    <Button
                        x:Name="ActivateOemButton"
                        Width="172"
                        Height="35"
                        Margin="5,0,0,0"
                        Background="#2D2D30"
                        Content="Ativar"
                        IsEnabled="False"
                        Style="{StaticResource OemActivateButtonStyle}" />
                </StackPanel>

                <Rectangle
                    Grid.Row="4"
                    Height="1"
                    Margin="0,20,0,20"
                    HorizontalAlignment="Stretch"
                    Fill="#3F3F46" />
                <Border
                    Grid.Row="5"
                    Width="30"
                    Height="30"
                    Margin="0,0,0,10"
                    HorizontalAlignment="Center"
                    Background="#383838"
                    CornerRadius="15">
                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontFamily="Segoe MDL2 Assets"
                        FontSize="16"
                        Foreground="White"
                        Text="&#xE756;" />
                </Border>

                <!--  Conteúdo do Passo 2  -->
                <StackPanel Grid.Row="6" HorizontalAlignment="Center">
                    <TextBlock
                        Margin="0,0,0,5"
                        HorizontalAlignment="Center"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Text="Ativação complementar" />
                </StackPanel>
                <Button
                    x:Name="ActivateWindowsMasButton"
                    Grid.Row="7"
                    Grid.Column="0"
                    Width="250"
                    Height="35"
                    Margin="0,5,0,15"
                    Padding="12,8"
                    Content="Abrir ativador MAS"
                    Style="{StaticResource CommonDangerActionButtonStyle}" />
            </Grid>
        </Grid>
    </Border>
</Window>