<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Limpeza de permissões"
    Width="450"
    Height="Auto"
    MinHeight="300"
    MaxHeight="700"
    AllowsTransparency="True"
    Background="Transparent"
    FontFamily="Futura"
    Foreground="White"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    SizeToContent="Height"
    WindowStartupLocation="CenterOwner"
    WindowStyle="None">
    <Window.Resources>
        <!--  Estilo para botões de ação individuais  -->
        <Style
            x:Key="ActionButtonStyle"
            BasedOn="{StaticResource CommonDialogButtonStyle}"
            TargetType="Button">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Margin" Value="5,2" />
            <Setter Property="MinWidth" Value="100" />
            <Setter Property="Height" Value="30" />
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.5" />
                    <Setter Property="Background" Value="#666666" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style BasedOn="{StaticResource CommonDialogTextBlockStyle}" TargetType="TextBlock" />
    </Window.Resources>
    <Border
        x:Name="DialogBorder"
        Background="#1E1E1E"
        BorderBrush="#3F3F46"
        BorderThickness="1"
        CornerRadius="5"
        Effect="{x:Null}">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!--  Barra de título  -->
            <Border Grid.Row="0" CornerRadius="5,5,0,0">
                <Grid>
                    <TextBlock
                        x:Name="DialogTitleTextBlock"
                        Margin="15,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Foreground="White"
                        Text="Limpeza de permissões" />

                    <Button
                        x:Name="CloseButton"
                        Margin="0,0,5,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Content="✕"
                        Style="{StaticResource CommonMutedCloseButtonStyle}" />
                </Grid>
            </Border>

            <!--  Conteúdo principal  -->
            <Grid Grid.Row="1" Margin="15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border
                    Grid.Row="0"
                    Width="30"
                    Height="30"
                    Margin="0,0,0,10"
                    HorizontalAlignment="Center"
                    Background="#383838"
                    CornerRadius="15">
                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontFamily="Segoe MDL2 Assets"
                        FontSize="16"
                        Foreground="White"
                        Text="&#xE1F7;" />
                </Border>
                <TextBlock
                    Grid.Row="1"
                    Margin="0,0,0,10"
                    HorizontalAlignment="Center"
                    FontSize="12"
                    Text="Clique em 'Limpar' ao lado de cada pasta para iniciar o processo de limpeza. É normal que a janela não exiba nada. Apenas aguarde o processo terminar."
                    TextAlignment="Center"
                    TextWrapping="Wrap" />

                <!--  Lista de pastas com botões  -->
                <ScrollViewer
                    Grid.Row="2"
                    MaxHeight="450"
                    Margin="0,0,0,15"
                    Padding="10"
                    Background="#383838"
                    BorderBrush="#505050"
                    BorderThickness="1"
                    VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="FoldersStackPanel" Orientation="Vertical" />
                    <ScrollViewer.Resources>
                        <!--  Estilo discreto para a scrollbar, consistente com TweaksDialog  -->
                        <Style BasedOn="{StaticResource SlimScrollBarStyle}" TargetType="{x:Type ScrollBar}" />
                    </ScrollViewer.Resources>
                </ScrollViewer>

                <!--  Botões de controle  -->
                <StackPanel
                    Grid.Row="3"
                    HorizontalAlignment="Center"
                    Orientation="Horizontal">
                    <Button
                        x:Name="ClearPersistedButton"
                        Width="180"
                        Height="35"
                        Margin="0,0,10,0"
                        Background="#993233"
                        Content="Limpar seleção de pastas"
                        Style="{StaticResource CommonDialogButtonStyle}" />
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>