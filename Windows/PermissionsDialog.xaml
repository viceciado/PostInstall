<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Limpeza de permissões" Width="450" MinHeight="300" Height="Auto" SizeToContent="Height"
        WindowStyle="None" WindowStartupLocation="CenterOwner" ShowInTaskbar="False" ResizeMode="NoResize" MaxHeight="700"
        AllowsTransparency="True" Background="Transparent" Foreground="White" FontFamily="Futura">
    <Window.Resources>
        <!-- Estilo para botões de ação individuais -->
        <Style x:Key="ActionButtonStyle" TargetType="Button" BasedOn="{StaticResource CommonDialogButtonStyle}">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="5,2"/>
            <Setter Property="MinWidth" Value="100"/>
            <Setter Property="Height" Value="30"/>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.5"/>
                    <Setter Property="Background" Value="#666666"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <Style TargetType="TextBlock" BasedOn="{StaticResource CommonDialogTextBlockStyle}"/>
    </Window.Resources>
    <Border x:Name="DialogBorder" 
            Background="#1E1E1E" 
            BorderBrush="#3F3F46" 
            BorderThickness="1" 
            CornerRadius="5"
            Effect="{x:Null}">
        
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- Barra de título -->
            <Border Grid.Row="0" CornerRadius="5,5,0,0">
                <Grid>
                    <TextBlock x:Name="DialogTitleTextBlock" 
                               Text="Limpeza de permissões" 
                               Foreground="White" 
                               FontSize="14" 
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" 
                               HorizontalAlignment="Left" 
                               Margin="15,0"/>
                    
                    <Button x:Name="CloseButton" 
                            Content="✕" 
                            Style="{StaticResource CommonMutedCloseButtonStyle}"
                            HorizontalAlignment="Right" 
                            VerticalAlignment="Center" 
                            Margin="0,0,5,0"/>
                </Grid>
            </Border>
            
            <!-- Conteúdo principal -->
            <Grid Grid.Row="1" Margin="15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <Border Grid.Row="0" Width="30"
                            Height="30"
                            Background="#383838"
                            CornerRadius="15"
                            Margin="0,0,0,10"
                            HorizontalAlignment="Center">
                        <TextBlock Text="&#xE1F7;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="16"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Grid.Row="1"
                               Text="Clique em 'Limpar' ao lado de cada pasta para iniciar o processo de limpeza. É normal que a janela não exiba nada. Apenas aguarde o processo terminar."
                               FontSize="12"
                               Margin="0,0,0,10"
                               HorizontalAlignment="Center"
                               TextWrapping="Wrap"
                               TextAlignment="Center"/>
                          
                <!-- Lista de pastas com botões -->
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" MaxHeight="450" Margin="0,0,0,15" 
                             Background="#383838" Padding="10" BorderBrush="#505050" BorderThickness="1">
                    <StackPanel x:Name="FoldersStackPanel" Orientation="Vertical"/>
                    <ScrollViewer.Resources>
                        <!-- Estilo discreto para a scrollbar, consistente com TweaksDialog -->
                        <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource SlimScrollBarStyle}"/>
                    </ScrollViewer.Resources>
                </ScrollViewer>
                
                <!-- Botões de controle -->
                <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button x:Name="ClearPersistedButton" Content="Limpar seleção de pastas" Width="180" Height="35" 
                           Style="{StaticResource CommonDialogButtonStyle}" Background="#993233" Margin="0,0,10,0"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>