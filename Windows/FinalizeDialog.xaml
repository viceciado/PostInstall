<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Finalizar instalação" Width="500" Height="Auto" SizeToContent="Height" 
        WindowStyle="None" WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False" ResizeMode="NoResize" Topmost="False"
        AllowsTransparency="True" Background="Transparent" Foreground="White" FontFamily="Futura">
    <Window.Resources>
        <Style TargetType="CheckBox" BasedOn="{StaticResource CommonCheckBoxStyle}">
            <Setter Property="Margin" Value="0,3"/>
        </Style>
        <Style TargetType="TextBox" BasedOn="{StaticResource CommonDialogInputTextBoxStyle}">
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        <Style TargetType="TextBlock" BasedOn="{StaticResource CommonDialogTextBlockStyle}">
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
        <Style TargetType="RadioButton">
            <Setter Property="Foreground" Value="LightGray"/>
            <Setter Property="FontFamily" Value="Futura"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="5,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="BorderBrush" Value="#1E1E1E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="FocusBorder" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <BulletDecorator>
                                <BulletDecorator.Bullet>
                                    <Grid Width="14" Height="14" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="5,0,0,0">
                                        <Ellipse Stroke="{TemplateBinding Foreground}" StrokeThickness="2"/>
                                        <Ellipse x:Name="InnerDot" Fill="{TemplateBinding Foreground}" Width="6" Height="6" Visibility="Collapsed"/>
                                    </Grid>
                                </BulletDecorator.Bullet>
                            <ContentPresenter VerticalAlignment="Center" Margin="8,0" RecognizesAccessKey="True"/>
                            </BulletDecorator>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="InnerDot" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="FocusBorder" Property="BorderBrush" Value="White"/>
                                <Setter TargetName="FocusBorder" Property="BorderThickness" Value="1"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <Border x:Name="DialogBorder" 
            Background="#1E1E1E" 
            BorderBrush="#3F3F46" 
            BorderThickness="1" 
            CornerRadius="5"
            Effect="{x:Null}">
        
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- Barra de título -->
            <Border Grid.Row="0" CornerRadius="5,5,0,0">
                <Grid>
                    <TextBlock x:Name="TitleText" 
                               Text="Finalizar instalação" 
                               Foreground="White" 
                               FontSize="14" 
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" 
                               HorizontalAlignment="Left" 
                               Margin="15,0"/>
                    
                    <Button x:Name="CloseButton" 
                            Content="✕" 
                            Style="{StaticResource CommonMutedCloseButtonStyle}"
                            HorizontalAlignment="Right" 
                            VerticalAlignment="Center" 
                            Margin="0,0,5,0"/>
                </Grid>
            </Border>
            
            <!-- Conteúdo principal -->
            <StackPanel Grid.Row="1" Margin="15">
                <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Margin="0,0,0,10">
                    <Border Width="30" 
                                Height="30" 
                                Background="#383838" 
                                CornerRadius="15" 
                                Margin="0,0,0,10"
                                HorizontalAlignment="Center">
                            <TextBlock Text="&#xE13D;"
                                    FontFamily="Segoe MDL2 Assets" 
                                    Foreground="White" 
                                    FontSize="16"
                                    HorizontalAlignment="Center" 
                                    VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Informações sobre o serviço" 
                                    FontSize="14"
                                    FontWeight="Bold"
                                    Margin="0,0,0,10"
                                    HorizontalAlignment="Center"/>
                    <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="LightGray">
                        Estas informações são opcionais. Se fornecidas, serão usadas para registrar o proprietário no sistema (visível em 'winver') e para o log de instalação.
                    </TextBlock>
                </StackPanel>

                <!-- Linha para OS e Cliente -->
                <Grid Grid.Row="1" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/> 
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Nº OS:"/>
                        <TextBox x:Name="OsNumberTextBox" Width="70"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Cliente:"/>
                        <TextBox x:Name="ClientNameTextBox"/> <!-- Ocupará a largura da coluna "*" -->
                    </StackPanel>
                </Grid>

                <TextBlock Grid.Row="2" Text="Técnico:" Margin="0,0,0,5"/>
                <TextBox x:Name="TechnicianTextBox" Grid.Row="3"/>

                <!-- Separador 1 -->
                <Border Height="1" 
                        Background="#505050" 
                        Margin="0,0,0,10"/>

                <TextBlock Text="Parâmetros de finalização" 
                               FontSize="14" 
                               FontWeight="SemiBold"
                               Margin="0,0,0,10"
                               HorizontalAlignment="Left"/>

                <ScrollViewer x:Name="FinalizeTweaksScrollViewer"
                                      VerticalScrollBarVisibility="Auto"
                                      MaxHeight="150"
                                      Margin="0,0,0,15" 
                                      Background="#1E1E1E"
                                      BorderBrush="#505050" 
                                      BorderThickness="1">
                            <StackPanel x:Name="FinalizeTweaksStackPanel" Orientation="Vertical"/>
                            <ScrollViewer.Resources>
                                <!-- Estilo discreto para a scrollbar -->
                                <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource SlimScrollBarStyle}"/>
                            </ScrollViewer.Resources>
                        </ScrollViewer>
                <TextBlock Text="Encerramento" FontSize="14" FontWeight="SemiBold" Margin="0,10" HorizontalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                    <RadioButton x:Name="FinalizeOptionExitRadio" Content="Encerrar script" GroupName="FinalizeActionGroup" IsChecked="True"/>
                    <RadioButton x:Name="FinalizeOptionShutdownRadio" Content="Desligar" GroupName="FinalizeActionGroup"/>
                    <RadioButton x:Name="FinalizeOptionRestartRadio" Content="Reiniciar" GroupName="FinalizeActionGroup"/>
                </StackPanel>
                <TextBlock x:Name="FinalizeStatusText" Text="" FontSize="12" Foreground="LightGray" HorizontalAlignment="Center" Visibility="Collapsed"/>
                <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                    <Button x:Name="FinalizeOkButton" Content="Finalizar" Style="{StaticResource CommonFilledDialogButtonStyle}" Background="#4CAF50" Width="120" Height="35"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</Window>
