<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Finalizar instalação"
    Width="500"
    Height="Auto"
    AllowsTransparency="True"
    Background="Transparent"
    FontFamily="Futura"
    Foreground="White"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    SizeToContent="Height"
    Topmost="False"
    WindowStartupLocation="CenterOwner"
    WindowStyle="None">
    <Window.Resources>
        <Style BasedOn="{StaticResource CommonCheckBoxStyle}" TargetType="CheckBox">
            <Setter Property="Margin" Value="0,3" />
        </Style>
        <Style BasedOn="{StaticResource CommonDialogInputTextBoxStyle}" TargetType="TextBox">
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>
        <Style BasedOn="{StaticResource CommonDialogTextBlockStyle}" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,0,5" />
        </Style>
        <Style TargetType="RadioButton">
            <Setter Property="Foreground" Value="LightGray" />
            <Setter Property="FontFamily" Value="Futura" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Margin" Value="5,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="#1E1E1E" />
            <Setter Property="BorderBrush" Value="#1E1E1E" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border
                            x:Name="FocusBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="3">
                            <BulletDecorator>
                                <BulletDecorator.Bullet>
                                    <Grid
                                        Width="14"
                                        Height="14"
                                        Margin="5,0,0,0"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                        <Ellipse Stroke="{TemplateBinding Foreground}" StrokeThickness="2" />
                                        <Ellipse
                                            x:Name="InnerDot"
                                            Width="6"
                                            Height="6"
                                            Fill="{TemplateBinding Foreground}"
                                            Visibility="Collapsed" />
                                    </Grid>
                                </BulletDecorator.Bullet>
                                <ContentPresenter
                                    Margin="8,0"
                                    VerticalAlignment="Center"
                                    RecognizesAccessKey="True" />
                            </BulletDecorator>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="InnerDot" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="FocusBorder" Property="BorderBrush" Value="White" />
                                <Setter TargetName="FocusBorder" Property="BorderThickness" Value="1" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border
        x:Name="DialogBorder"
        Background="#1E1E1E"
        BorderBrush="#3F3F46"
        BorderThickness="1"
        CornerRadius="5"
        Effect="{x:Null}">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!--  Barra de título  -->
            <Border Grid.Row="0" CornerRadius="5,5,0,0">
                <Grid>
                    <TextBlock
                        x:Name="TitleText"
                        Margin="15,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Foreground="White"
                        Text="Finalizar instalação" />

                    <Button
                        x:Name="CloseButton"
                        Margin="0,0,5,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Content="✕"
                        Style="{StaticResource CommonMutedCloseButtonStyle}" />
                </Grid>
            </Border>

            <!--  Conteúdo principal  -->
            <StackPanel Grid.Row="1" Margin="15">
                <StackPanel
                    Margin="0,0,0,10"
                    HorizontalAlignment="Center"
                    Orientation="Vertical">
                    <Border
                        Width="30"
                        Height="30"
                        Margin="0,0,0,10"
                        HorizontalAlignment="Center"
                        Background="#383838"
                        CornerRadius="15">
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontFamily="Segoe MDL2 Assets"
                            FontSize="16"
                            Foreground="White"
                            Text="&#xE13D;" />
                    </Border>
                    <TextBlock
                        Margin="0,0,0,10"
                        HorizontalAlignment="Center"
                        FontSize="14"
                        FontWeight="Bold"
                        Text="Informações sobre o serviço" />
                    <TextBlock
                        FontSize="11"
                        Foreground="LightGray"
                        TextWrapping="Wrap">
                        Estas informações são opcionais. Se fornecidas, serão usadas para registrar o proprietário no sistema (visível em 'winver') e para o log de instalação.
                    </TextBlock>
                </StackPanel>

                <!--  Linha para OS e Cliente  -->
                <Grid Grid.Row="1" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Nº OS:" />
                        <TextBox x:Name="OsNumberTextBox" Width="70" />
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Cliente:" />
                        <TextBox x:Name="ClientNameTextBox" />
                        <!--  Ocupará a largura da coluna "*"  -->
                    </StackPanel>
                </Grid>

                <TextBlock
                    Grid.Row="2"
                    Margin="0,0,0,5"
                    Text="Técnico:" />
                <TextBox x:Name="TechnicianTextBox" Grid.Row="3" />

                <!--  Separador 1  -->
                <Border
                    Height="1"
                    Margin="0,0,0,10"
                    Background="#505050" />

                <TextBlock
                    Margin="0,0,0,10"
                    HorizontalAlignment="Left"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Text="Parâmetros de finalização" />

                <ScrollViewer
                    x:Name="FinalizeTweaksScrollViewer"
                    MaxHeight="150"
                    Margin="0,0,0,15"
                    Background="#1E1E1E"
                    BorderBrush="#505050"
                    BorderThickness="1"
                    VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="FinalizeTweaksStackPanel" Orientation="Vertical" />
                    <ScrollViewer.Resources>
                        <!--  Estilo discreto para a scrollbar  -->
                        <Style BasedOn="{StaticResource SlimScrollBarStyle}" TargetType="{x:Type ScrollBar}" />
                    </ScrollViewer.Resources>
                </ScrollViewer>
                <TextBlock
                    Margin="0,10"
                    HorizontalAlignment="Center"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Text="Encerramento" />
                <StackPanel
                    Margin="0,0,0,10"
                    HorizontalAlignment="Center"
                    Orientation="Horizontal">
                    <RadioButton
                        x:Name="FinalizeOptionExitRadio"
                        Content="Encerrar script"
                        GroupName="FinalizeActionGroup"
                        IsChecked="True" />
                    <RadioButton
                        x:Name="FinalizeOptionShutdownRadio"
                        Content="Desligar"
                        GroupName="FinalizeActionGroup" />
                    <RadioButton
                        x:Name="FinalizeOptionRestartRadio"
                        Content="Reiniciar"
                        GroupName="FinalizeActionGroup" />
                </StackPanel>
                <TextBlock
                    x:Name="FinalizeStatusText"
                    HorizontalAlignment="Center"
                    FontSize="12"
                    Foreground="LightGray"
                    Text=""
                    Visibility="Collapsed" />
                <StackPanel
                    Grid.Row="5"
                    Margin="0,10,0,0"
                    HorizontalAlignment="Center"
                    Orientation="Horizontal">
                    <Button
                        x:Name="FinalizeOkButton"
                        Width="120"
                        Height="35"
                        Background="#28A745"
                        Content="Finalizar"
                        Style="{StaticResource CommonFilledDialogButtonStyle}" />
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</Window>
