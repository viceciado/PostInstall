<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Gerenciador de Programas"
    Width="500"
    Height="Auto"
    MaxHeight="700"
    AllowsTransparency="True"
    Background="Transparent"
    FontFamily="Futura"
    Foreground="White"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    SizeToContent="Height"
    WindowStartupLocation="CenterOwner"
    WindowStyle="None">
    <Window.Resources>
        <Style BasedOn="{StaticResource CommonCheckBoxStyle}" TargetType="CheckBox" />

        <Style BasedOn="{StaticResource CommonDialogInputTextBoxStyle}" TargetType="TextBox" />

    </Window.Resources>
    <Border
        x:Name="DialogBorder"
        Background="#1E1E1E"
        BorderBrush="#3F3F46"
        BorderThickness="1"
        CornerRadius="5"
        Effect="{x:Null}">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!--  Barra de título  -->
            <Border Grid.Row="0" CornerRadius="5,5,0,0">
                <Grid>
                    <TextBlock
                        x:Name="TitleText"
                        Margin="15,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Foreground="White"
                        Text="Instalação de programas" />

                    <Button
                        x:Name="CloseButton"
                        Margin="0,0,5,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Content="✕"
                        Style="{StaticResource CommonMutedCloseButtonStyle}" />
                </Grid>
            </Border>

            <!--  Conteúdo principal  -->
            <StackPanel Grid.Row="1" Margin="15">
                <!--  Área 1 - Seleção de Programas  -->
                <StackPanel
                    Margin="0,0,0,20"
                    HorizontalAlignment="Center"
                    Orientation="Vertical">
                    <!--  Círculo com número 2  -->
                    <Border
                        Width="30"
                        Height="30"
                        Margin="0,0,0,10"
                        HorizontalAlignment="Center"
                        Background="#383838"
                        CornerRadius="15">
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontFamily="Segoe MDL2 Assets"
                            FontSize="16"
                            Foreground="White"
                            Text="&#xE118;" />
                    </Border>

                    <!--  Conteúdo do Passo 1  -->
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock
                            Margin="0,0,0,10"
                            HorizontalAlignment="Center"
                            FontSize="14"
                            Text="Selecione os programas para instalar via Winget" />
                        <ScrollViewer
                            Width="400"
                            MaxHeight="250"
                            Margin="0,0,0,15"
                            Padding="10"
                            Background="#383838"
                            BorderBrush="#505050"
                            BorderThickness="1"
                            VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="ProgramsStackPanelDialog" Orientation="Vertical" />
                            <ScrollViewer.Resources>
                                <!--  Estilo discreto para a scrollbar  -->
                                <Style BasedOn="{StaticResource SlimScrollBarStyle}" TargetType="{x:Type ScrollBar}" />
                            </ScrollViewer.Resources>
                        </ScrollViewer>

                        <TextBlock
                            Margin="0,0,0,5"
                            HorizontalAlignment="Center"
                            FontSize="14"
                            Text="Instalação manual via ID no Winget (separe por vírgula)" />
                        <TextBox
                            x:Name="CustomProgramIDsTextBox"
                            Width="400"
                            Height="30"
                            Margin="0,0,0,15" />

                        <Button
                            x:Name="InstallSelectedButtonDialog"
                            Width="180"
                            Height="35"
                            HorizontalAlignment="Center"
                            Background="#993233"
                            Content="Instalar"
                            Style="{StaticResource CommonDialogButtonStyle}" />
                    </StackPanel>
                </StackPanel>

                <!--  Separador 1  -->
                <Border
                    Height="1"
                    Margin="0,0,0,20"
                    Background="#505050" />

                <!--  Área 2 - Atualizar Programas  -->
                <StackPanel
                    Margin="0,0,0,10"
                    HorizontalAlignment="Center"
                    Orientation="Vertical">
                    <!--  Círculo com número 3  -->
                    <Border
                        Width="30"
                        Height="30"
                        Margin="0,0,0,10"
                        HorizontalAlignment="Center"
                        Background="#383838"
                        CornerRadius="15">
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontFamily="Segoe MDL2 Assets"
                            FontSize="16"
                            Foreground="White"
                            Text="&#xE117;" />
                    </Border>

                    <!--  Botão do Passo 2  -->
                    <Button
                        x:Name="UpdateAllProgramsButton"
                        Width="220"
                        Height="35"
                        HorizontalAlignment="Center"
                        Background="#28A745"
                        Content="Atualizar todos os programas"
                        Style="{StaticResource CommonDialogButtonStyle}" />
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</Window>