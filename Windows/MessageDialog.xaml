<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Mensagem"
    MinWidth="450"
    MinHeight="100"
    MaxWidth="500"
    MaxHeight="500"
    AllowsTransparency="True"
    Background="Transparent"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    SizeToContent="WidthAndHeight"
    WindowStartupLocation="CenterOwner"
    WindowStyle="None">

    <Window.Resources />

    <Border
        x:Name="DialogBorder"
        Background="#1E1E1E"
        BorderBrush="#3F3F46"
        BorderThickness="1"
        CornerRadius="5"
        Effect="{x:Null}">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40" />
                <RowDefinition Height="*" />
                <RowDefinition Height="50" />
            </Grid.RowDefinitions>

            <!--  Barra de título  -->
            <Border
                Grid.Row="0"
                Background="#2D2D30"
                CornerRadius="5,5,0,0">
                <Grid>
                    <TextBlock
                        x:Name="TitleText"
                        Margin="15,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Foreground="White"
                        Text="Mensagem" />

                    <Button
                        x:Name="CloseButton"
                        Margin="0,0,5,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Content="✕"
                        Style="{StaticResource CommonMutedCloseButtonStyle}" />
                </Grid>
            </Border>

            <!--  Conteúdo da mensagem  -->
            <Grid Grid.Row="1" Margin="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" MaxWidth="720" />
                </Grid.ColumnDefinitions>

                <!--  Ícone  -->
                <TextBlock
                    x:Name="IconText"
                    Grid.Column="0"
                    Margin="0,5,15,0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    FontFamily="Segoe MDL2 Assets"
                    FontSize="32" />

                <!--  ScrollViewer para o texto da mensagem  -->
                <ScrollViewer
                    Grid.Column="1"
                    MaxHeight="350"
                    CanContentScroll="True"
                    HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Auto">
                    <ScrollViewer.Resources>
                        <!--  Estilo discreto para a scrollbar  -->
                        <Style BasedOn="{StaticResource SlimScrollBarStyle}" TargetType="{x:Type ScrollBar}" />
                    </ScrollViewer.Resources>

                    <!--  Texto da mensagem  -->
                    <TextBlock
                        x:Name="MessageText"
                        MaxWidth="720"
                        VerticalAlignment="Top"
                        FontSize="13"
                        Foreground="White"
                        LineHeight="18"
                        Text="Mensagem"
                        TextWrapping="Wrap" />
                </ScrollViewer>
            </Grid>

            <!--  Botões  -->
            <StackPanel
                Grid.Row="2"
                Margin="20,0,20,15"
                HorizontalAlignment="Right"
                Orientation="Horizontal">

                <Button
                    x:Name="Button1"
                    MinWidth="80"
                    Content="OK"
                    Style="{StaticResource CommonFilledDialogButtonStyle}" />

                <Button
                    x:Name="Button2"
                    MinWidth="80"
                    Content="Cancelar"
                    Style="{StaticResource CommonFilledDialogButtonStyle}"
                    Visibility="Collapsed" />

                <Button
                    x:Name="Button3"
                    MinWidth="80"
                    Content="Sim"
                    Style="{StaticResource CommonFilledDialogButtonStyle}"
                    Visibility="Collapsed" />
            </StackPanel>
        </Grid>
    </Border>
</Window>