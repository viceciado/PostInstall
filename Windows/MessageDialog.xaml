<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mensagem"
        MinHeight="100"
        MinWidth="450"
        MaxHeight="500"
        MaxWidth="500"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        ShowInTaskbar="False"
        AllowsTransparency="True"
        Background="Transparent">
    
    <Window.Resources/>
    
    <Border x:Name="DialogBorder" 
            Background="#1E1E1E" 
            BorderBrush="#3F3F46" 
            BorderThickness="1" 
            CornerRadius="5"
            Effect="{x:Null}">
        
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="50"/>
            </Grid.RowDefinitions>
            
            <!-- Barra de título -->
            <Border Grid.Row="0" Background="#2D2D30" CornerRadius="5,5,0,0">
                <Grid>
                    <TextBlock x:Name="TitleText" 
                               Text="Mensagem" 
                               Foreground="White" 
                               FontSize="14" 
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" 
                               HorizontalAlignment="Left" 
                               Margin="15,0"/>
                    
                    <Button x:Name="CloseButton"
                            Content="✕"
                            Style="{StaticResource CommonMutedCloseButtonStyle}"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Margin="0,0,5,0"/>
                </Grid>
            </Border>
            
            <!-- Conteúdo da mensagem -->
            <Grid Grid.Row="1" Margin="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*" MaxWidth="720"/>
                </Grid.ColumnDefinitions>
                
                <!-- Ícone -->
                <TextBlock x:Name="IconText" 
                           Grid.Column="0"
                           FontSize="32" 
                           FontFamily="Segoe MDL2 Assets"
                           VerticalAlignment="Top" 
                           HorizontalAlignment="Center" 
                           Margin="0,5,15,0"/>
                
                <!-- ScrollViewer para o texto da mensagem -->
                <ScrollViewer Grid.Column="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              MaxHeight="350"
                              CanContentScroll="True">
                    <ScrollViewer.Resources>
                        <!-- Estilo discreto para a scrollbar -->
                        <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource SlimScrollBarStyle}"/>
                    </ScrollViewer.Resources>
                    
                    <!-- Texto da mensagem -->
                    <TextBlock x:Name="MessageText" 
                               Text="Mensagem" 
                               Foreground="White" 
                               FontSize="13" 
                               TextWrapping="Wrap" 
                               VerticalAlignment="Top" 
                               LineHeight="18"
                               MaxWidth="720"/>
                </ScrollViewer>
            </Grid>
            
            <!-- Botões -->
            <StackPanel Grid.Row="2" 
                        Orientation="Horizontal" 
                        HorizontalAlignment="Right" 
                        Margin="20,0,20,15">
                
                <Button x:Name="Button1" 
                        Content="OK" 
                    Style="{StaticResource CommonFilledDialogButtonStyle}"
                        MinWidth="80"/>
                
                <Button x:Name="Button2" 
                        Content="Cancelar" 
                    Style="{StaticResource CommonFilledDialogButtonStyle}"
                        MinWidth="80"
                        Visibility="Collapsed"/>
                
                <Button x:Name="Button3" 
                        Content="Sim" 
                    Style="{StaticResource CommonFilledDialogButtonStyle}"
                        MinWidth="80"
                        Visibility="Collapsed"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>